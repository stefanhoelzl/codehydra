{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "rootDir": "..",
    "outDir": "../../out",
    "baseUrl": "../..",
    "paths": {
      "$lib/*": ["src/renderer/lib/*"],
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": ["../env.d.ts", "./**/*", "../shared/**/*", "../intents/contract.ts", "../test/**/*"],
  "exclude": [
    "../../node_modules",
    "../../app-data",
    "../test/setup-matchers.ts",
    "../test/global-setup-boundary.ts"
  ]
}
