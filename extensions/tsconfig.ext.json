{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "declaration": false,
    "noEmit": true,
    "verbatimModuleSyntax": false,
    "exactOptionalPropertyTypes": false,
    "types": ["node", "vscode"]
  },
  "include": ["dictation/src/**/*", "sidekick/src/**/*"],
  "exclude": ["*/node_modules", "*/dist"]
}
