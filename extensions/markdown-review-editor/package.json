{
	"name": "markdown-review-editor",
	"displayName": "Markdown Review Editor",
	"description": "AI-assisted collaborative markdown document editor",
	"version": "0.1.0-dev.6686f318",
	"type": "module",
	"publisher": "codehydra",
	"repository": {
		"type": "git",
		"url": "https://github.com/stefanhoelzl/codehydra"
	},
	"engines": {
		"vscode": "^1.108.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [],
	"main": "./dist/extension.cjs",
	"contributes": {
		"commands": [
			{
				"command": "markdownReviewEditor.open",
				"title": "Open Markdown Review Editor",
				"category": "Markdown Review"
			}
		],
		"customEditors": [
			{
				"viewType": "markdownReviewEditor.editor",
				"displayName": "Markdown Review Editor",
				"selector": [
					{
						"filenamePattern": "*.md"
					}
				],
				"priority": "option"
			}
		]
	},
	"scripts": {
		"build": "vite build",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"format": "prettier --write .",
		"lint": "eslint . && prettier --check .",
		"lint:fix": "eslint . --fix && prettier --write ."
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@sveltejs/vite-plugin-svelte": "^5.1.1",
		"@types/diff-match-patch": "^1.0.36",
		"@types/marked": "^5.0.2",
		"@types/node": "^22.19.15",
		"@types/turndown": "^5.0.6",
		"@types/vscode": "~1.108.0",
		"eslint": "^9.39.4",
		"eslint-plugin-svelte": "^2.46.1",
		"globals": "^15.15.0",
		"jsdom": "^27.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.53.12",
		"svelte-check": "^4.4.5",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^6.4.1",
		"vitest": "^2.1.9"
	},
	"dependencies": {
		"@opencode-ai/sdk": "^1.2.26",
		"diff-match-patch": "^1.0.5",
		"marked": "^17.0.4",
		"turndown": "^7.2.2"
	}
}
