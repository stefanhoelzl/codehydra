{
  "name": "codehydra",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "bash -c 'OUTPUT=$(prettier --check . 2>&1); echo \"$OUTPUT\"; if echo \"$OUTPUT\" | grep -q SyntaxError; then exit 1; fi'",
    "rust:clippy": "cd src-tauri && cargo clippy --all-targets --all-features -- -D warnings",
    "rust:fmt": "cd src-tauri && cargo fmt",
    "rust:fmt:check": "cd src-tauri && cargo fmt -- --check",
    "rust:test": "cd src-tauri && cargo test --all-features",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:debug": "pnpm tauri build --debug --no-bundle",
    "build:release": "pnpm tauri build",
    "validate": "pnpm format:check && pnpm lint && pnpm check && pnpm build",
    "validate:full": "pnpm format:check && pnpm lint && pnpm check && pnpm rust:fmt:check && pnpm rust:clippy && pnpm build",
    "tauri": "tauri"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-opener": "^2",
    "@vscode-elements/elements": "^2.3.1",
    "@vscode/codicons": "^0.0.42"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^9.39.1",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.2.9",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.13.0",
    "globals": "^16.5.0",
    "happy-dom": "^20.0.10",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-eslint-parser": "^1.4.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.47.0",
    "vite": "^6.0.3",
    "vitest": "^4.0.13"
  }
}
