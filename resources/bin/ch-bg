#!/bin/sh
# CodeHydra background wrapper.
#
# Runs the given command transparently (same stdio, same exit code). Its only
# job is to put the "ch-bg" marker into the command string CodeHydra sees in
# Claude Code's background_tasks, so this background shell is excluded from
# keeping the workspace busy. Wrap long-lived background processes (dev servers,
# watchers, tail -f) with it:  ch-bg npm run dev
exec "$@"
